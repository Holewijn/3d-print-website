NODE_ENV=production
PORT=3000
HOST=0.0.0.0
PUBLIC_URL=http://localhost:3000

DATABASE_URL=postgresql://print3d:CHANGE_ME@localhost:5432/print3d

JWT_SECRET=CHANGE_ME_TO_LONG_RANDOM_STRING
JWT_EXPIRES_IN=7d
SESSION_COOKIE_NAME=p3d_session

ADMIN_EMAIL=admin@local
ADMIN_PASSWORD=CHANGE_ME

UPLOAD_DIR=/var/lib/print3d/uploads
MAX_UPLOAD_MB=200

MOLLIE_API_KEY=
MOLLIE_WEBHOOK_URL=

ENERGY_PROVIDER=manual
ENERGY_PRICE_KWH=0.30
ZONNEPLAN_API_KEY=

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="3D Print <noreply@local>"

GIT_REPO_URL=https://github.com/Holewijn/3d-print-website.git
GIT_BRANCH=main
APP_DIR=/opt/print3d
