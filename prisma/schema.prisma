generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String
  role          Role     @default(CUSTOMER)
  firstName     String?
  lastName      String?
  phone         String?
  addressLine1  String?
  addressLine2  String?
  city          String?
  postalCode    String?
  country       String?  @default("NL")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  orders        Order[]
  quotes        Quote[]
  stlUploads    StlUpload[]
}

enum Role {
  CUSTOMER
  ADMIN
}

model Page {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  content   Json
  seoTitle  String?
  seoDesc   String?
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Setting {
  key   String @id
  value Json
}

model Product {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String
  priceCents  Int
  weightG     Int      @default(100)
  stock       Int      @default(0)
  images      Json
  category    String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  orderItems  OrderItem[]
}

model Order {
  id              String      @id @default(cuid())
  userId          String?
  user            User?       @relation(fields: [userId], references: [id])
  email           String
  status          OrderStatus @default(PENDING)
  subtotalCents   Int         @default(0)
  shippingCents   Int         @default(0)
  totalCents      Int
  currency        String      @default("EUR")
  molliePaymentId String?     @unique
  shippingName    String?
  shippingPhone   String?
  shippingAddr    Json?
  shippingMethod  String?
  items           OrderItem[]
  invoice         Invoice?
  quoteId         String?     @unique
  quote           Quote?      @relation(fields: [quoteId], references: [id])
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

enum OrderStatus {
  PENDING
  PAID
  IN_PRODUCTION
  SHIPPED
  COMPLETED
  CANCELLED
  REFUNDED
}

model OrderItem {
  id         String   @id @default(cuid())
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId  String?
  product    Product? @relation(fields: [productId], references: [id])
  name       String
  priceCents Int
  qty        Int
}

model Quote {
  id                String      @id @default(cuid())
  userId            String?
  user              User?       @relation(fields: [userId], references: [id])
  email             String
  stlUploadId       String
  stlUpload         StlUpload   @relation(fields: [stlUploadId], references: [id])
  material          String
  materialId        String?
  materialRef       Material?   @relation(fields: [materialId], references: [id])
  colorId           String?
  colorRef          Color?      @relation(fields: [colorId], references: [id])
  infillPct         Int         @default(20)
  layerHeightMm     Float       @default(0.2)
  volumeCm3         Float?
  weightG           Float?
  printMinutes      Int?
  energyKwh         Float?
  materialCostCents Int?
  energyCostCents   Int?
  machineCostCents  Int?
  marginCents       Int?
  totalCents        Int?
  status            QuoteStatus @default(NEW)
  adminNote         String?
  order             Order?
  printJob          PrintJob?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
}

enum QuoteStatus {
  NEW
  PRICED
  APPROVED
  REJECTED
  CONVERTED
}

model StlUpload {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  filename   String
  storedPath String
  sizeBytes  Int
  sha256     String
  createdAt  DateTime @default(now())
  quotes     Quote[]
}

// ─── Inventory: Brand / Material / Color / Spool ──────

model Brand {
  id          String   @id @default(cuid())
  name        String   @unique
  websiteUrl  String?
  logoUrl     String?
  supportEmail String?
  notes       String?
  active      Boolean  @default(true)
  spools      Spool[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Material {
  id              String           @id @default(cuid())
  name            String           @unique  // "PLA", "PETG", "ABS"...
  densityGcm3     Float            @default(1.24)
  printTempC      Int?
  bedTempC        Int?
  abrasive        Boolean          @default(false)
  notes           String?
  active          Boolean          @default(true)
  spools          Spool[]
  materialColors  MaterialColor[]
  quotes          Quote[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model Color {
  id              String           @id @default(cuid())
  name            String           @unique
  hex             String           @default("#000000")
  swatchUrl       String?
  spools          Spool[]
  materialColors  MaterialColor[]
  quotes          Quote[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

// List price per (material, color) combination — used by the quote engine.
// FIFO costing is separate and stored on movements.
model MaterialColor {
  id              String   @id @default(cuid())
  materialId      String
  material        Material @relation(fields: [materialId], references: [id], onDelete: Cascade)
  colorId         String
  color           Color    @relation(fields: [colorId], references: [id], onDelete: Cascade)
  listPriceKgCents Int     @default(2500)   // €25/kg default
  lowStockGrams   Int      @default(500)    // alert when total stock for this combo drops below
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  @@unique([materialId, colorId])
}

// A physical spool you've purchased. Each is tracked individually for FIFO.
model Spool {
  id                String              @id @default(cuid())
  brandId           String
  brand             Brand               @relation(fields: [brandId], references: [id])
  materialId        String
  material          Material            @relation(fields: [materialId], references: [id])
  colorId           String
  color             Color               @relation(fields: [colorId], references: [id])
  diameterMm        Float               @default(1.75)
  initialGrams      Int                 // weight at purchase
  remainingGrams    Int                 // current
  pricePaidCents    Int                 // total paid for this spool (incl tax & shipping)
  supplier          String?
  purchaseDate      DateTime            @default(now())
  batchCode         String?
  notes             String?
  status            SpoolStatus         @default(IN_STOCK)
  movements         FilamentMovement[]
  loadedOnPrinterId String?             @unique
  loadedOnPrinter   Printer?            @relation(fields: [loadedOnPrinterId], references: [id])
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  @@index([materialId, colorId])
  @@index([status, purchaseDate])
}

enum SpoolStatus {
  IN_STOCK
  IN_USE
  EMPTY
  DISPOSED
}

model FilamentMovement {
  id          String           @id @default(cuid())
  spoolId     String
  spool       Spool            @relation(fields: [spoolId], references: [id], onDelete: Cascade)
  deltaGrams  Int              // negative = consumed, positive = added (e.g. correction)
  reason      MovementReason
  costCents   Int              // cost-of-goods at FIFO price for this movement
  printJobId  String?
  printJob    PrintJob?        @relation(fields: [printJobId], references: [id])
  note        String?
  createdAt   DateTime         @default(now())
  @@index([spoolId, createdAt])
  @@index([reason, createdAt])
}

enum MovementReason {
  PURCHASE         // initial when spool created
  PRINT_USED       // consumed during a successful print
  FAILED_PRINT     // wasted on a failed print
  DISPOSED         // dried out / contaminated / thrown away
  LOST             // missing
  MANUAL_ADJUST    // admin correction
}

model FilamentAlert {
  id           String        @id @default(cuid())
  materialId   String
  material     Material      @relation(fields: [materialId], references: [id])
  colorId      String
  color        Color         @relation(fields: [colorId], references: [id])
  thresholdG   Int
  currentG     Int
  read         Boolean       @default(false)
  emailSent    Boolean       @default(false)
  createdAt    DateTime      @default(now())
  @@index([read, createdAt])
}

// ─── Print queue ───────────────────────────────────────

model PrintJob {
  id              String         @id @default(cuid())
  quoteId         String?        @unique
  quote           Quote?         @relation(fields: [quoteId], references: [id])
  printerId       String?
  printer         Printer?       @relation(fields: [printerId], references: [id])
  spoolId         String?        // override spool — defaults to printer's loaded spool
  title           String         // human label, e.g. "Quote #abc12345"
  status          PrintJobStatus @default(QUEUED)
  expectedGrams   Int?           // from quote
  actualGrams     Int?           // from Moonraker print_stats.filament_used
  startedAt       DateTime?
  finishedAt      DateTime?
  moonrakerJobId  String?
  notes           String?
  movements       FilamentMovement[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  @@index([status, createdAt])
}

enum PrintJobStatus {
  QUEUED
  PRINTING
  PENDING_REVIEW   // finished, waiting for admin to confirm filament deduction (CONFIRM mode)
  DONE
  FAILED
  CANCELLED
}

// ─── Printers ──────────────────────────────────────────

model Printer {
  id               String     @id @default(cuid())
  name             String
  moonrakerUrl     String
  apiKey           String?
  costPerHourCents Int        @default(0)
  active           Boolean    @default(true)
  lastStatus       Json?
  lastSeenAt       DateTime?
  loadedSpool      Spool?
  printJobs        PrintJob[]
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String?
  message   String
  handled   Boolean  @default(false)
  createdAt DateTime @default(now())
}

model PageView {
  id        String   @id @default(cuid())
  path      String
  referrer  String?
  ua        String?
  ip        String?
  createdAt DateTime @default(now())
  @@index([path])
  @@index([createdAt])
}

model ShippingZone {
  id        String         @id @default(cuid())
  name      String
  countries Json
  sortOrder Int            @default(0)
  active    Boolean        @default(true)
  rates     ShippingRate[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model ShippingRate {
  id             String       @id @default(cuid())
  zoneId         String
  zone           ShippingZone @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  name           String
  type           RateType     @default(FLAT)
  costCents      Int          @default(0)
  freeAboveCents Int?
  minOrderCents  Int?
  sortOrder      Int          @default(0)
  active         Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

enum RateType {
  FLAT
  FREE
  FREE_OVER
  WEIGHT
}

model Invoice {
  id              String    @id @default(cuid())
  number          String    @unique
  year            Int
  sequence        Int
  orderId         String    @unique
  order           Order     @relation(fields: [orderId], references: [id])
  issuedAt        DateTime  @default(now())
  dueAt           DateTime?
  paidAt          DateTime?
  companyName     String
  companyAddress  Json
  companyKvk      String?
  companyBtw      String?
  companyIban     String?
  companyBic      String?
  companyBank     String?
  customerName    String
  customerEmail   String
  customerAddress Json
  subtotalCents   Int
  vatRate         Float
  vatCents        Int
  shippingCents   Int
  totalCents      Int
  lineItems       Json
  notes           String?
  emailSent       Boolean   @default(false)
  emailSentAt     DateTime?
  pdfPath         String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([year, sequence])
}
